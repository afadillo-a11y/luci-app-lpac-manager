#!/bin/sh
set +e

echo "=============================================="
echo " luci-app-lpac-esim installed."
echo ""
echo " LuCI WebUI for eSIM profile management."
echo " Requires lpac-esim-qmi backend (installed separately)."
echo ""
echo " Navigate to: Modem → eSIM Manager"
echo "=============================================="

if [ -x /etc/init.d/rpcd ]; then
    /etc/init.d/rpcd reload >/dev/null 2>&1 || true
fi

rm -rf /tmp/luci-modulecache /tmp/luci-indexcache* >/dev/null 2>&1 || true

logger -t lpac-esim "LuCI app installed."
exit 0
