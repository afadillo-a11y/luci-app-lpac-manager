#!/bin/sh
# postinst — luci-app-lpac-manager v1.3.5
set +e

echo "=============================================="
echo " luci-app-lpac-manager installed."
echo ""
echo " Includes: lpac-esim backend script"
echo " and LuCI eSIM Manager web interface."
echo ""
echo " Prerequisites (install separately):"
echo "   lpac, libqmi/qmi-utils, luci-base, jq"
echo "   For MBIM: libmbim/mbim-utils"
echo ""
echo " Navigate to: Modem → eSIM Manager"
echo "=============================================="

chmod +x /usr/bin/lpac-esim 2>/dev/null || true

# Fix directory permissions (opkg/nfpm may strip them)
chmod 755 /usr/share/luci/menu.d 2>/dev/null || true
chmod 755 /usr/share/rpcd/acl.d 2>/dev/null || true

if [ -x /etc/init.d/rpcd ]; then
    /etc/init.d/rpcd reload >/dev/null 2>&1 || true
fi

rm -rf /tmp/luci-modulecache /tmp/luci-indexcache* >/dev/null 2>&1 || true

logger -t lpac-esim "luci-app-lpac-manager v1.3.5 installed."
exit 0
