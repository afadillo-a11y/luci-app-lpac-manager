{
  "luci-app-lpac-esim": {
    "description": "LuCI WebUI for eSIM management via lpac-esim-qmi backend",
    "read": {
      "uci": ["lpac-esim"],
      "file": {
        "/usr/bin/lpac-esim-qmi": ["exec"],
        "/usr/bin/lpac":          ["exec"],
        "/usr/sbin/qmicli":       ["exec"],
        "/sbin/logread":          ["exec"]
      }
    },
    "write": {
      "uci": ["lpac-esim"]
    }
  }
}
