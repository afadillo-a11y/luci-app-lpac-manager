{
  "luci-app-lpac-manager": {
    "description": "LuCI WebUI for eSIM management via lpac backend",
    "read": {
      "uci": [
        "lpac-esim"
      ],
      "file": {
        "/usr/bin/lpac-esim": [
          "exec"
        ],
        "/usr/sbin/qmicli": [
          "exec"
        ],
        "/sbin/logread": [
          "exec"
        ]
      }
    },
    "write": {
      "uci": [
        "lpac-esim"
      ]
    }
  }
}
